# Supabase/Postgres
DATABASE_URL=postgresql+psycopg://postgres:your_password@db.your-project-id.supabase.co:5432/postgres
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql+psycopg://postgres:your_password@db.your-project-id.supabase.co:5432/postgres

# JWT
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Twilio (SMS alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Owner contact
OWNER_PHONE=+1xxxxxxxxxx
OWNER_EMAIL=owner@restaurant.com

# How many minutes after shift start before a no-show alert fires
CHECKIN_GRACE_MINUTES=30

# Optional Slack/Discord webhook for alerts
WEBHOOK_URL=

# SMTP (optional email alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=msy_waiter
SMTP_PASSWORD=placeholder

# Security hardening
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=^https://([a-zA-Z0-9-]+\.)*vercel\.app$
CORS_ALLOW_CREDENTIALS=true
TRUSTED_HOSTS=localhost,127.0.0.1,*.vercel.app

MAX_REQUEST_BODY_BYTES=1000000
SECURITY_HEADERS_ENABLED=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=300/minute
RATE_LIMIT_LOGIN=20/minute
RATE_LIMIT_CHECKIN=30/minute

AUTH_LOCKOUT_ENABLED=true
AUTH_ATTEMPT_WINDOW_SECONDS=300
AUTH_MAX_ATTEMPTS=20
AUTH_LOCKOUT_SECONDS=60

TRUST_PROXY_HEADERS=true

# Optional Redis cache (recommended for manager dashboard/schedule pages)
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_NAMESPACE=shiftdock
CACHE_TENANT_ID=default
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_TTL_JITTER_SECONDS=5
CACHE_TTL_DASHBOARD_SECONDS=20
CACHE_TTL_SCHEDULE_SECONDS=45
CACHE_TTL_TASKS_SECONDS=180
CACHE_TTL_ANALYTICS_SECONDS=300

